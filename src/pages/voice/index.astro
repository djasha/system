---
import { getCollection } from 'astro:content';
import DocLayout from '../../layouts/DocLayout.astro';
const voice = await getCollection('voice');
const sorted = voice.sort((a, b) => a.data.topic.localeCompare(b.data.topic));
---
<DocLayout title="Voice" description="How the system sounds when it talks.">
  <header class="mb-10">
    <h1 class="font-display text-5xl tracking-tight">Voice</h1>
    <p class="text-xl text-bone/70 mt-3">How the system sounds when it talks — rules and examples for headlines, microcopy, and more.</p>
  </header>

  {sorted.map((v) => (
    <section class="mb-16">
      <h2 class="font-display text-2xl mb-2">{v.data.topic}</h2>
      <p class="text-bone/70 mb-6">{v.data.description}</p>
      <ul class="list-disc pl-5 space-y-2 text-bone/80 mb-8">
        {v.data.rules.map((r: string) => <li>{r}</li>)}
      </ul>
      {v.data.examples.length > 0 && (
        <div class="grid sm:grid-cols-2 gap-3">
          {v.data.examples.map((e: any) => (
            <div class="p-5 border border-bone/10 rounded-lg bg-elevated/40">
              <p class="text-xs font-mono text-accent mb-2 uppercase tracking-wide">Good</p>
              <p class="mb-4">{e.good}</p>
              <p class="text-xs font-mono text-bone/40 mb-2 uppercase tracking-wide">Bad</p>
              <p class="text-bone/60 line-through">{e.bad}</p>
            </div>
          ))}
        </div>
      )}
    </section>
  ))}
</DocLayout>
