---
import { getCollection } from 'astro:content';
import DocLayout from '../../layouts/DocLayout.astro';
import { ComponentFilters } from '../../components/chrome/ComponentFilters';

const components = await getCollection('components');
const items = components
  .sort((a, b) => a.data.name.localeCompare(b.data.name))
  .map((c) => ({
    slug: c.id,
    name: c.data.name,
    description: c.data.description,
    category: c.data.category,
    tags: c.data.tags,
    tokens_used: c.data.tokens_used,
  }));
---
<DocLayout title="Components" description="Browse the full component library.">
  <header class="mb-10">
    <h1 class="font-display text-5xl tracking-tight">Components</h1>
    <p class="text-xl text-bone/70 mt-3">{items.length} component{items.length === 1 ? '' : 's'}. Copy code, prompts, or full bundles into any AI agent.</p>
  </header>
  <ComponentFilters client:idle items={items} />
</DocLayout>
