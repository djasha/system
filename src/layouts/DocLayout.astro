---
import BaseLayout from './BaseLayout.astro';
interface Props { title: string; description?: string; ogImage?: string; jsonLd?: object | object[]; }
const { title, description, ogImage, jsonLd } = Astro.props;
---
<BaseLayout title={title} description={description} ogImage={ogImage} jsonLd={jsonLd}>
  <main class="max-w-content mx-auto px-6 py-16">
    <slot />
  </main>
</BaseLayout>
