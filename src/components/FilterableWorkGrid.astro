---
import { ToolTicker } from './ToolTicker';
import { ProjectCard } from './ProjectCard';

interface Props {
  projects: Array<{ title: string; description: string; href: string; imageSrc?: string; imageAlt?: string; tags?: string[] }>;
  tools?: Array<{ name: string; icon?: string; color?: string }>;
  heading: string;
  intro?: string;
}

const { projects, tools, heading, intro } = Astro.props;
---
<div class="max-w-content mx-auto py-16 px-6">
  <header class="mb-10">
    <h1 class="font-display text-5xl tracking-tight mb-4">{heading}</h1>
    {intro && <p class="text-xl text-bone/70 max-w-2xl">{intro}</p>}
  </header>

  {tools && tools.length > 0 && (
    <div class="mb-12 -mx-6 overflow-hidden">
      <ToolTicker client:visible tools={tools} speed={40} />
    </div>
  )}

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {projects.map((p) => (
      <ProjectCard client:idle {...p} />
    ))}
  </div>
</div>
