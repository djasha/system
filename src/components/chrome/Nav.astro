---
import { ThemeToggle } from './ThemeToggle';
const links = [
  { href: '/components', label: 'Components' },
  { href: '/patterns', label: 'Patterns' },
  { href: '/tokens', label: 'Tokens' },
  { href: '/voice', label: 'Voice' },
  { href: '/about', label: 'About' },
  { href: '/api', label: 'API' },
  { href: '/integrations', label: 'Integrations' },
];
const current = Astro.url.pathname;
---
<nav class="border-b border-bone/10 bg-ink/80 backdrop-blur sticky top-0 z-40">
  <div class="max-w-content mx-auto px-6 py-3 flex items-center justify-between gap-4">
    <a href="/" class="font-display text-lg hover:text-accent transition-colors">Djasha System</a>
    <ul class="hidden md:flex gap-6 text-sm font-mono items-center">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class={current.startsWith(l.href) ? 'text-accent' : 'text-bone/70 hover:text-bone transition-colors'}
          >{l.label}</a>
        </li>
      ))}
      <li><ThemeToggle client:idle /></li>
      <li>
        <a href="https://github.com/djasha/system" target="_blank" rel="noreferrer" class="text-bone/70 hover:text-bone transition-colors" aria-label="GitHub repository">
          GitHub
        </a>
      </li>
    </ul>
    <span class="md:hidden text-xs font-mono text-bone/50">⌘K to search</span>
  </div>
</nav>
