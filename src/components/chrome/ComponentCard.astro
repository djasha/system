---
interface Props { slug: string; name: string; description: string; category: string; tags: string[]; }
const { slug, name, description, category, tags } = Astro.props;
---
<a href={`/components/${slug}`} class="block p-5 border border-bone/10 rounded-lg bg-elevated/40 hover:border-accent/60 transition-colors group">
  <div class="flex justify-between items-start mb-2 gap-3">
    <h3 class="font-display text-lg group-hover:text-accent transition-colors">{name}</h3>
    <span class="text-xs font-mono text-bone/50 uppercase shrink-0">{category}</span>
  </div>
  <p class="text-sm text-bone/70 mb-3 leading-relaxed">{description}</p>
  <div class="flex flex-wrap gap-1">
    {tags.map((t) => <span class="text-xs font-mono text-bone/50">#{t}</span>)}
  </div>
</a>
